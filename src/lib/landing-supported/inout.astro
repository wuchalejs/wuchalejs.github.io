---
import { Code } from '@astrojs/starlight/components';

type Props = {
    input: string
    output?: string
    lang: string
}

const {input, output, lang}: Props = Astro.props
---

<div class="versions">
    <div>
        <Code code={input} lang={lang} title="INPUT" />
    </div>
    <div>
        <Code code={output ?? input} lang={lang} title="OUTPUT" />
    </div>
</div>

<style>
    .versions {
        display: flex;
		flex-wrap: wrap;
        align-items: flex-start;
        width: 100%;
    }

    .versions div {
        margin: 0;
        flex-grow: 1;
        overflow: auto;
    }
</style>

---
import {getTypeCache} from './get-type-cache.ts'
import { Code } from '@astrojs/starlight/components';
import type {Opts} from './get-type.ts'

type Props = Opts & {file: string, name: string, ignore?: string}

const {file, name, ignore, ...opts} = Astro.props

const code = await getTypeCache(file, name, {ignore: ignore?.split(','), ...opts})
---

<Code code={code} lang="ts" />
